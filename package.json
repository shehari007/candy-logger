  "description": "A beautiful browser-based logger with table view UI, tags, colors, action buttons, and dark/light themes",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
